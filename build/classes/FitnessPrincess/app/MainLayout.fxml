<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane
        fx:id="rootPane"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="FitnessPrincess.app.MainLayoutController"
        stylesheets="@/resources/estilos.css">

    <top>
        <HBox fx:id="desktopNav" styleClass="nav-bar" spacing="8" alignment="CENTER_LEFT">

            <Label text="🏃 Running la Safor" styleClass="nav-brand"/>

            <Button fx:id="navActivities" text="Activities" styleClass="nav-btn" onAction="#showActivities"/>
            <Button fx:id="navProfile" text="Profile" styleClass="nav-btn" onAction="#showProfile"/>
            <Button fx:id="navHistory" text="Session History" styleClass="nav-btn" onAction="#showSessionHistory"/>
            <Button fx:id="navMaps" text="Manage Maps" styleClass="nav-btn" onAction="#showMapManagement"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUserNick" styleClass="nav-user" text=""/>
            <Button fx:id="navSignOut" text="Sign Out" styleClass="nav-logout-btn" onAction="#handleLogout"/>

        </HBox>
    </top>

    <center>
    </center>

    <bottom>
        <HBox fx:id="mobileNav" styleClass="tab-bar" spacing="0" alignment="CENTER"
              managed="false" visible="false">

            <Button fx:id="tabActivities" text="A" styleClass="tab-btn" onAction="#showActivities" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabProfile" text="P" styleClass="tab-btn" onAction="#showProfile" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabHistory" text="H" styleClass="tab-btn" onAction="#showSessionHistory" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabMaps" text="M" styleClass="tab-btn" onAction="#showMapManagement" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabSignOut" text="S" styleClass="tab-btn" onAction="#handleLogout" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

        </HBox>
    </bottom>

</BorderPane>
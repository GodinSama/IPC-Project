<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.shape.Circle?>

<BorderPane
        fx:id="rootPane"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="FitnessPrincess.app.MainLayoutController"
        stylesheets="@../../resources/estilos.css">

    <top>
        <HBox fx:id="desktopNav" styleClass="nav-bar" spacing="8" alignment="CENTER_LEFT">

            <Label text="🏃 Fitness" styleClass="nav-brand"/>
            <Label text="Princess" styleClass="nav-brand-2"/>
            <Button fx:id="navDashboard" text="Dashboard" styleClass="nav-btn" onAction="#showDashboard"/>
            <Button fx:id="navHistory" text="Session History" styleClass="nav-btn" onAction="#showSessionHistory"/>
            <Button fx:id="navMaps" text="Manage Maps" styleClass="nav-btn" onAction="#showMapManagement"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUserNick" styleClass="nav-user" text=""/>

            <Button fx:id="navProfile" onAction="#showProfile" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 10 0 5;">
                <graphic>
                    <Circle fx:id="navAvatarCircle" radius="16.0" fill="#e0e0e0" stroke="#cccccc" strokeWidth="1.0" />
                </graphic>
            </Button>

        </HBox>
    </top>

    <center>
    </center>

    <bottom>
        <HBox fx:id="mobileNav" styleClass="tab-bar" spacing="0" alignment="CENTER" managed="false" visible="false">
            <Button fx:id="tabDashboard" text="D" styleClass="tab-btn" onAction="#showDashboard" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabProfile" text="P" styleClass="tab-btn" onAction="#showProfile" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabHistory" text="H" styleClass="tab-btn" onAction="#showSessionHistory" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="tabMaps" text="M" styleClass="tab-btn" onAction="#showMapManagement" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </bottom>

</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="FitnessPrincess.auth.RegisterController"
      stylesheets="@../../resources/estilos.css"
      styleClass="auth-root"
      alignment="CENTER"
      spacing="0">

    <VBox alignment="CENTER" spacing="15" maxWidth="420" styleClass="auth-card">
        <padding>
            <Insets top="40" right="60" bottom="40" left="60"/>
        </padding>

        <HBox alignment="CENTER_LEFT" maxWidth="Infinity">
            <VBox.margin><Insets bottom="0" left="-20" top="-20"/></VBox.margin>
            <Button text="← Back" onAction="#handleLogin" styleClass="back-btn"/>
        </HBox>

        <Label text="Register" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #000000; -fx-padding: 0 0 10 0;"/>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="#555555" styleClass="field-icon-monochromatic"/>
                <Label text="Nickname*" styleClass="field-label"/>
            </HBox>

            <HBox styleClass="input-container-box">
                <TextField fx:id="txtUsername" promptText="Enter name" styleClass="input-embedded" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="usernameError" wrapText="true" minHeight="-Infinity" maxWidth="Infinity" style="-fx-text-fill: #d32f2f; -fx-font-size: 11px;" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="#555555" styleClass="field-icon-monochromatic"/>
                <Label text="Email*" styleClass="field-label"/>
            </HBox>

            <HBox styleClass="input-container-box">
                <TextField fx:id="txtEmail" promptText="Enter email" styleClass="input-embedded" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="emailError" wrapText="true" minHeight="-Infinity" maxWidth="Infinity" style="-fx-text-fill: #d32f2f; -fx-font-size: 11px;" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" fill="#555555" styleClass="field-icon-monochromatic"/>
                <Label text="Password*" styleClass="field-label"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" styleClass="input-container-box">
                <StackPane HBox.hgrow="ALWAYS">
                    <PasswordField fx:id="txtPasswordMasked" promptText="Enter password" styleClass="input-embedded"/>
                    <TextField fx:id="txtPasswordVisible" promptText="Enter password" styleClass="input-embedded" visible="false" managed="false"/>
                </StackPane>
                <StackPane onMouseClicked="#handleTogglePassword" style="-fx-cursor: hand;">
                    <padding><Insets right="10"/></padding>
                    <SVGPath fx:id="eyeIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.81l2.91 2.91C21.03 15.17 22.19 13.66 23 12c-1.73-4.39-6-7.5-11-7.5-.68 0-1.35.05-2 .14l2.25 2.25C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.41-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.34-4.34L13.91 9.9c-.14-.28-.35-.53-.6-.71z" fill="#757575"/>
                </StackPane>
            </HBox>
            <Label fx:id="passwordError" wrapText="true" minHeight="-Infinity" maxWidth="Infinity" style="-fx-text-fill: #d32f2f; -fx-font-size: 11px;" visible="false" managed="false"/>
        </VBox>

        <Separator opacity="0.3">
            <VBox.margin><Insets top="8" bottom="4"/></VBox.margin>
        </Separator>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" fill="#555555" styleClass="field-icon-monochromatic"/>
                <Label text="Date of birth*" styleClass="field-label"/>
            </HBox>
            <HBox styleClass="input-container-box">
                <DatePicker fx:id="valueBirthdate" promptText="DD/MM/YYYY" styleClass="input-embedded" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="birthdateError" wrapText="true" minHeight="-Infinity" maxWidth="Infinity" style="-fx-text-fill: #d32f2f; -fx-font-size: 11px;" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="10">
            <VBox.margin><Insets top="15"/></VBox.margin>

            <HBox alignment="CENTER_LEFT" spacing="5">
                <Label text="Already have an account?" styleClass="auth-footer-text"/>
                <Button text="Sign In" onAction="#handleLogin" styleClass="signin-link-fat"/>
            </HBox>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="nextBtn" text="Next ➔" defaultButton="true" onAction="#handleNext" styleClass="next-btn"
                        style="-fx-background-color: #cccccc; -fx-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 10 24 10 24;"/>
            </HBox>
        </VBox>

    </VBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="FitnessPrincess.activities.ActivityMapController"
            styleClass="view-container"
            stylesheets="@../../resources/estilos.css">

    <top>
        <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="12">
            <Button text="Back" onAction="#goBack" styleClass="nav-btn"/>
            <Label text="Create Activity" styleClass="maps-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-transparent">
            <content>
                <VBox alignment="TOP_CENTER" style="-fx-padding: 32 24 32 24;">

                    <VBox styleClass="map-creation-card" spacing="20"
                          maxWidth="420" minWidth="320">

                        <VBox spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="📤" styleClass="field-label"/>
                                <Label text="Upload Route" styleClass="field-label"/>
                            </HBox>

                            <StackPane styleClass="drop-zone"
                                       fx:id="dropZone"
                                       minHeight="90">
                                <VBox alignment="CENTER" spacing="8">
                                    <Label fx:id="dropZoneLabel" text="Upload your .gpx file here" styleClass="drop-zone-text"/>
                                    <Label text="🗺️" styleClass="drop-zone-icon"/>
                                </VBox>
                            </StackPane>

                            <HBox alignment="CENTER">
                                <Button text="Import file" styleClass="primary-btn" onAction="#handleImport"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Activity Name" styleClass="field-label"/>
                            <TextField fx:id="activityNameField"
                                       promptText="e.g. Sunday Morning Run"
                                       styleClass="input-field"/>
                        </VBox>

                        <Label fx:id="errorLabel" styleClass="error-label"
                               wrapText="true" visible="false" managed="false"/>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save Activity" styleClass="save-btn" defaultButton="true" onAction="#handleSave"/>
                        </HBox>

                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
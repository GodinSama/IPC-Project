<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="FitnessPrincess.maps.MapManagementController"
        stylesheets="@../../resources/estilos.css"
        styleClass="view-container">

    <top>
        <VBox styleClass="maps-top-bar" spacing="12">

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="My maps and regions" styleClass="maps-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addMapBtn" text="+" onAction="#onAddMap" styleClass="add-map-btn"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="6" styleClass="search-bar" HBox.hgrow="ALWAYS">
                    <Label text="🔍" styleClass="search-icon"/>
                    <TextField fx:id="searchField" promptText="Search maps…" styleClass="search-field" HBox.hgrow="ALWAYS"/>
                </HBox>
            </HBox>

        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="maps-scroll" hbarPolicy="NEVER" vbarPolicy="NEVER">
            <VBox fx:id="mapsContainer" spacing="12" styleClass="maps-container">

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Valencia Regional Offline" styleClass="card-dark card-title map-card-name"/>
                        <Label text="Offline coverage for city and surroundings" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  39.3500 (S) to 39.5500 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -0.4500 (W) to -0.2500 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Sierra Calderona Loop - Trail" styleClass="card-dark card-title map-card-name"/>
                        <Label text="Trails and detailed terrain" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  39.6300 (S) to 39.7800 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -0.5800 (W) to -0.3600 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Pirineos - Trail Running" styleClass="card-dark card-title map-card-name"/>
                        <Label text="High mountain maps" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  42.5800 (S) to 42.7200 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -1.0000 (W) to 0.0800 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Pirineos - Trail Running" styleClass="card-dark card-title map-card-name"/>
                        <Label text="High mountain maps" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  42.5800 (S) to 42.7200 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -1.0000 (W) to 0.0800 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Pirineos - Trail Running" styleClass="card-dark card-title map-card-name"/>
                        <Label text="High mountain maps" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  42.5800 (S) to 42.7200 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -1.0000 (W) to 0.0800 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

                <HBox styleClass="map-card" spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="map-thumbnail">
                        <Label text="" styleClass="map-thumbnail-icon"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Pirineos - Trail Running" styleClass="card-dark card-title map-card-name"/>
                        <Label text="High mountain maps" styleClass="card-dark card-subtitle"/>
                        <Label text="Latitude:  42.5800 (S) to 42.7200 (N)" styleClass="map-coord"/>
                        <Label text="Longitude: -1.0000 (W) to 0.0800 (E)" styleClass="map-coord"/>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

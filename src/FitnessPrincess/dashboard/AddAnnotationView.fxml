<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: rgba(0,0,0,0.5);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    
    <VBox alignment="TOP_CENTER" maxWidth="340.0" maxHeight="-Infinity" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 0);">
        <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
        </padding>

        <HBox alignment="TOP_RIGHT">
            <Button fx:id="closeAnnotationBtn" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #333; -fx-padding: 0;" text="ⓧ">
                <font><Font size="18.0" /></font>
            </Button>
        </HBox>

        <Label text="Add Annotation" styleClass="annotation-title">
            <VBox.margin><Insets top="-25.0" bottom="5.0"/></VBox.margin>
        </Label>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M17 1H7c-1.1 0-2 .9-2 2v4H2v2h3v6H2v2h3v4c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2v-4h3v-2h-3V9h3V7h-3V3c0-1.1-.9-2-2-2zM7 3h10v4H7V3zm10 18H7v-4h10v4z" fill="#555555" scaleX="0.6" scaleY="0.6"/>
                <Label text="Type" style="-fx-text-fill: #333; -fx-font-family: monospace;"/>
            </HBox>
            <HBox style="-fx-background-color: #e8f5e9; -fx-border-color: #555; -fx-border-radius: 8; -fx-background-radius: 8;">
                <ComboBox fx:id="typeComboBox" 
                          style="-fx-background-color: transparent; -fx-font-family: monospace; -fx-focused-color: #00d684; -fx-faint-focused-color: rgba(0,214,132,0.1);" 
                          maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="#555555" scaleX="0.7" scaleY="0.7"/>
                <Label text="Text" style="-fx-text-fill: #333; -fx-font-family: monospace;"/>
            </HBox>
            <HBox style="-fx-background-color: #e8f5e9; -fx-border-color: #555; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0;">
                <TextArea fx:id="annotationTextArea" promptText="Write your text here" prefRowCount="3" wrapText="true" 
                          style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-font-family: monospace; -fx-text-fill: #333; -fx-focused-color: #00d684; -fx-faint-focused-color: rgba(0,214,132,0.1); -fx-prompt-text-fill: #aaaaaa;"/>
            </HBox>
        </VBox>

        <VBox spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <SVGPath content="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1-.23-.27-.38-.62-.38-.98 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 9 6.5 9 8 9.67 8 10.5 7.33 12 6.5 12zm3-4C8.67 8 8 7.33 8 6.5S8.67 5 9.5 5s1.5.67 1.5 1.5S10.33 8 9.5 8zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 5 14.5 5s1.5.67 1.5 1.5S15.33 8 14.5 8zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 9 17.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="#555555" scaleX="0.7" scaleY="0.7"/>
                <Label text="Color" style="-fx-text-fill: #333; -fx-font-family: monospace;"/>
            </HBox>
            <HBox style="-fx-background-color: #e8f5e9; -fx-border-color: #555; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 4;">
                <ColorPicker fx:id="markerColorPicker" 
                             style="-fx-background-color: transparent; -fx-focused-color: #00d684; -fx-faint-focused-color: rgba(0,214,132,0.1);" 
                             maxWidth="Infinity" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <HBox fx:id="strokeWidthContainer" alignment="CENTER_RIGHT" spacing="10">
            <Label text="Stroke width:" style="-fx-text-fill: #333; -fx-font-family: monospace;"/>
            <Spinner fx:id="strokeWidthSpinner" prefWidth="80" 
                     style="-fx-background-color: #e8f5e9; -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-family: monospace; -fx-focused-color: #00d684; -fx-faint-focused-color: rgba(0,214,132,0.1);"/>
        </HBox>

        <HBox alignment="BOTTOM_RIGHT" spacing="15">
            <VBox.margin><Insets top="10"/></VBox.margin>
            <Button fx:id="cancelBtn" text="Cancel" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-family: monospace; -fx-text-fill: #333;"/>
            <Button fx:id="saveAnnotationBtn" text="Done" defaultButton="true" style="-fx-background-color: #00d684; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5 15 5 15; -fx-font-family: monospace;"/>
        </HBox>

    </VBox>
</StackPane>
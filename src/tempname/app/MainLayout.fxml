<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane
    fx:id="rootPane"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="tempname.app.MainLayoutController"
    stylesheets="@/resources/estilos.css">

    <!-- ═══ TOP — Navigation bar ═══════════════════════════════════════ -->
    <top>
        <HBox styleClass="nav-bar" spacing="8" alignment="CENTER_LEFT">

            <Label text="🏃 Running la Safor" styleClass="nav-brand"/>

            <Button text="Activities"       styleClass="nav-btn" onAction="#showActivities"/>
            <Button text="Profile"          styleClass="nav-btn" onAction="#showProfile"/>
            <Button text="Session History"  styleClass="nav-btn" onAction="#showSessionHistory"/>
            <Button text="Manage Maps"      styleClass="nav-btn" onAction="#showMapManagement"/>

            <!-- pushes logout to the far right -->
            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUserNick" styleClass="nav-user" text=""/>
            <Button text="Sign Out" styleClass="nav-logout-btn" onAction="#handleLogout"/>

        </HBox>
    </top>

    <!-- ═══ CENTER — swapped at runtime by MainLayoutController ════════ -->
    <!-- Leave empty. loadView() injects content here. -->
    <center>
        <!-- intentionally empty -->
    </center>

</BorderPane>
